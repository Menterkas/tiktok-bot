# 2. ОБРАБОТЧИК ОБЫЧНЫХ СООБЩЕНИЙ
@bot.message_handler(func=lambda message: True)
def handle_message(message):
    url = message.text.strip()
    
    # Проверяем, если пользователь написал просто приветствие или "старт" текстом
    if url.lower() in ["старт", "start", "привет", "help", "помощь"]:
        bot.reply_to(message, "Привет! Пришли мне ссылку на TikTok, и я отправлю тебе видео без водяного знака. 🎬")
        return # Останавливаем выполнение функции, чтобы код ниже не выполнялся

    # Если это ссылка на TikTok
    if "tiktok.com" in url:
        status = bot.reply_to(message, "⏳ Обрабатываю...")
        try:
            api_url = f"https://www.tikwm.com/api/?url={url}"
            response = requests.get(api_url).json()
            if response.get('code') == 0:
                video_url = response['data']['play']
                bot.delete_message(message.chat.id, status.message_id)
                bot.send_video(message.chat.id, video_url)
            else:
                bot.edit_message_text("❌ Ошибка: не удалось получить видео.", message.chat.id, status.message_id)
        except Exception as e:
            bot.edit_message_text("❌ Ошибка соединения с сервером API.", message.chat.id, status.message_id)
    else:
        bot.reply_to(message, "⚠️ Пожалуйста, отправьте ссылку на TikTok.")

